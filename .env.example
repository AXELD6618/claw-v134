# V13.4 Cloud Environment Variables
# Copy to .env and fill in your values

# PushPlus Token (微信推送 — 必填)
# 获取: https://www.pushplus.plus/
PUSHPLUS_TOKEN=your_pushplus_token_here

# Server酱 Key (备用推送 — 可选)
# 获取: https://sct.ftqq.com/
SERVERCHAN_KEY=

# GitHub PAT (用于自动更新和Secret管理)
# 获取: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_pat_here

# 仓库信息
GITHUB_REPO=AXELD6618/claw-v134
GITHUB_BRANCH=master

# ============================================================
# V13.5.24 Cognee 长期记忆 LLM 配置（二选一即可）
# ============================================================
# 方案 A：OpenAI（推荐，知识图谱抽取质量最高）
# 获取: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# 方案 B：Ollama（本地免费，需先安装 Ollama 并拉取模型）
# 下载: https://ollama.com/download
# 启动后执行: ollama pull qwen2.5:7b 或 llama3:8b
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b

# 方案 C：其他兼容 OpenAI 接口的 LLM（如 DeepSeek/硅基流动等）
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
